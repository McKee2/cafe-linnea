---
interface Props {
  size?: 'narrow' | 'default' | 'wide';
  class?: string;
}

const { size = 'default', class: className = '' } = Astro.props;

const sizes = {
  narrow: 'max-w-3xl',
  default: 'max-w-5xl',
  wide: 'max-w-6xl',
};
---

<div class={`mx-auto px-6 sm:px-10 ${sizes[size]} ${className}`}>
  <slot />
</div>
