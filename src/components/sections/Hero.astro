---
import Button from '../Button.astro';
---

<section class="bg-cream relative overflow-hidden">
  <div class="grid grid-cols-1 lg:grid-cols-12 lg:min-h-[640px]">
    <!-- Left: Text content -->
    <div
      class="lg:col-span-7 px-6 sm:px-10 lg:pl-16 lg:pr-12 py-16 lg:py-24 flex flex-col justify-center order-2 lg:order-1"
    >
      <!-- Open status badge -->
      <div
        class="inline-flex items-center gap-2.5 self-start mb-8 px-3 py-1.5 rounded-full bg-sage/10 border border-sage/30"
      >
        <span class="relative flex h-2 w-2">
          <span
            class="animate-ping absolute inline-flex h-full w-full rounded-full bg-sage opacity-60"
          ></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-sage"
          ></span>
        </span>
        <span
          class="font-mono text-xs tracking-wide text-coffee uppercase"
        >
          Öppet nu · stänger 18:00
        </span>
      </div>

      <!-- Headline -->
      <h1
        class="font-serif font-light text-coffee text-5xl sm:text-6xl lg:text-7xl xl:text-[5.5rem] leading-[0.95] tracking-[-0.02em] mb-6"
      >
        Café <span class="italic font-normal text-terracotta">Linnea</span>
      </h1>

      <!-- Tagline -->
      <p
        class="font-serif italic text-2xl md:text-3xl lg:text-4xl text-coffee/85 mb-7 leading-tight"
      >
        Långsamt kaffe på Söder.
      </p>

      <!-- Description -->
      <p
        class="text-base md:text-lg text-coffee/75 max-w-md mb-10 leading-relaxed"
      >
        Surdegslimpa, hemrostat espresso och italienska kakor på Bondegatan 27. Öppet alla dagar, alltid med tid att stanna.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3">
        <Button href="#reservera" variant="primary" size="lg">
          Reservera bord →
        </Button>
        <Button href="#meny" variant="ghost" size="lg">
          Se menyn
        </Button>
      </div>

      <!-- Bottom info strip -->
      <div
        class="mt-14 pt-6 border-t border-coffee/15 flex flex-wrap gap-x-6 gap-y-2 text-xs font-mono text-coffee/60 uppercase tracking-wider"
      >
        <span>Bondegatan 27 · Stockholm</span>
        <span class="text-coffee/30">·</span>
        <span>08-123 45 67</span>
      </div>
    </div>

    <!-- Right: Atmospheric image -->
    <div
      class="lg:col-span-5 relative h-[320px] sm:h-[400px] lg:h-auto lg:min-h-[640px] order-1 lg:order-2"
    >
      <img
        src="https://images.unsplash.com/photo-1559496417-e7f25cb247f3?w=1400&q=80&auto=format&fit=crop"
        alt="Atmosfärisk bild av Café Linneas interiör med varmt morgonljus"
        class="absolute inset-0 w-full h-full object-cover"
        loading="eager"
        decoding="async"
      />
      <!-- Subtle gradient on left edge to blend into cream -->
      <div
        class="absolute inset-y-0 left-0 w-24 hidden lg:block bg-gradient-to-r from-cream/40 to-transparent pointer-events-none"
      >
      </div>
    </div>
  </div>
</section>
