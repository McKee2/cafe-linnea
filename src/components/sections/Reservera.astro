---
import Container from '../Container.astro';

// Time slots 08:00 – 17:00 in 30-min increments
const generateTimeSlots = (): string[] => {
  const slots: string[] = [];
  for (let hour = 8; hour <= 17; hour++) {
    slots.push(`${String(hour).padStart(2, '0')}:00`);
    if (hour < 17) slots.push(`${String(hour).padStart(2, '0')}:30`);
  }
  return slots;
};

const timeSlots = generateTimeSlots();
const partySize = [1, 2, 3, 4, 5, 6, 7, 8];

// Date constraints (today minimum, 3 months ahead maximum)
const today = new Date();
const todayStr = today.toISOString().split('T')[0];
const maxDate = new Date();
maxDate.setMonth(maxDate.getMonth() + 3);
const maxDateStr = maxDate.toISOString().split('T')[0];
---

<section
  id="reservera"
  class="bg-cream py-20 md:py-28 border-t border-coffee/8"
>
  <Container size="wide">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
      <!-- Left: Info column -->
      <div class="lg:col-span-5">
        <p
          class="font-mono text-xs uppercase tracking-[0.2em] text-coffee/60 mb-6"
        >
          Reservera
        </p>

        <h2
          class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-coffee tracking-[-0.02em] leading-[1.05] mb-6"
        >
          Boka ditt <span class="italic font-normal text-terracotta">bord.</span
          >
        </h2>

        <p
          class="text-base md:text-lg text-coffee/75 leading-relaxed mb-10 max-w-md"
        >
          Vi tar bordsreservationer för 2–8 personer. Större sällskap — ring
          direkt på 08-123 45 67.
        </p>

        <!-- Info points -->
        <dl class="space-y-6 mb-10">
          <div>
            <dt
              class="font-mono text-xs uppercase tracking-[0.15em] text-sage mb-1.5"
            >
              Bekräftelse
            </dt>
            <dd
              class="text-sm md:text-base text-coffee/80 leading-relaxed"
            >
              Du får svar inom 4 timmar — oftast snabbare.
            </dd>
          </div>
          <div>
            <dt
              class="font-mono text-xs uppercase tracking-[0.15em] text-sage mb-1.5"
            >
              Hålltid
            </dt>
            <dd
              class="text-sm md:text-base text-coffee/80 leading-relaxed"
            >
              Vi håller bordet i 15 minuter efter bokad tid.
            </dd>
          </div>
          <div>
            <dt
              class="font-mono text-xs uppercase tracking-[0.15em] text-sage mb-1.5"
            >
              Avbokning
            </dt>
            <dd
              class="text-sm md:text-base text-coffee/80 leading-relaxed"
            >
              Senast 2 timmar innan. Skicka mejl eller ring.
            </dd>
          </div>
        </dl>

        <!-- Walk-in note -->
        <p
          class="text-sm text-coffee/65 italic font-serif border-l-2 border-terracotta/40 pl-4 leading-relaxed"
        >
          Walk-ins är välkomna också — om vi har plats.
        </p>
      </div>

      <!-- Right: Form -->
      <div class="lg:col-span-7">
        <form
          id="reservation-form"
          class="bg-white/70 border border-coffee/10 rounded-sm p-6 sm:p-8 md:p-10 space-y-5"
        >
          <!-- Name + Email -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label
                for="r-name"
                class="block font-mono text-[10px] uppercase tracking-[0.18em] text-coffee/60 mb-2"
              >
                Namn <span class="text-sage">*</span>
              </label>
              <input
                type="text"
                id="r-name"
                name="name"
                required
                autocomplete="name"
                placeholder="Anna Andersson"
                class="w-full px-4 py-3 bg-cream/60 border border-coffee/15 rounded-sm text-coffee placeholder-coffee/30 focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20 transition-all"
              />
            </div>
            <div>
              <label
                for="r-email"
                class="block font-mono text-[10px] uppercase tracking-[0.18em] text-coffee/60 mb-2"
              >
                Mejl <span class="text-sage">*</span>
              </label>
              <input
                type="email"
                id="r-email"
                name="email"
                required
                autocomplete="email"
                placeholder="anna@example.se"
                class="w-full px-4 py-3 bg-cream/60 border border-coffee/15 rounded-sm text-coffee placeholder-coffee/30 focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20 transition-all"
              />
            </div>
          </div>

          <!-- Phone -->
          <div>
            <label
              for="r-phone"
              class="block font-mono text-[10px] uppercase tracking-[0.18em] text-coffee/60 mb-2"
            >
              Telefon
              <span class="text-coffee/30 normal-case tracking-normal"
                >(valfritt)</span
              >
            </label>
            <input
              type="tel"
              id="r-phone"
              name="phone"
              autocomplete="tel"
              placeholder="070 123 45 67"
              class="w-full px-4 py-3 bg-cream/60 border border-coffee/15 rounded-sm text-coffee placeholder-coffee/30 focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20 transition-all"
            />
          </div>

          <!-- Date + Time -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label
                for="r-date"
                class="block font-mono text-[10px] uppercase tracking-[0.18em] text-coffee/60 mb-2"
              >
                Datum <span class="text-sage">*</span>
              </label>
              <input
                type="date"
                id="r-date"
                name="date"
                required
                min={todayStr}
                max={maxDateStr}
                class="w-full px-4 py-3 bg-cream/60 border border-coffee/15 rounded-sm text-coffee focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20 transition-all"
              />
            </div>
            <div>
              <label
                for="r-time"
                class="block font-mono text-[10px] uppercase tracking-[0.18em] text-coffee/60 mb-2"
              >
                Tid <span class="text-sage">*</span>
              </label>
              <select
                id="r-time"
                name="time"
                required
                class="w-full px-4 py-3 bg-cream/60 border border-coffee/15 rounded-sm text-coffee focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20 transition-all"
              >
                <option value="">Välj tid…</option>
                {timeSlots.map((slot) => <option value={slot}>{slot}</option>)}
              </select>
            </div>
          </div>

          <!-- Party size -->
          <fieldset>
            <legend
              class="block font-mono text-[10px] uppercase tracking-[0.18em] text-coffee/60 mb-2"
            >
              Antal personer <span class="text-sage">*</span>
            </legend>
            <div class="grid grid-cols-4 sm:grid-cols-8 gap-2">
              {
                partySize.map((n) => (
                  <label class="cursor-pointer">
                    <input
                      type="radio"
                      name="party"
                      value={n}
                      class="peer sr-only"
                      required
                    />
                    <div class="text-center py-3 border border-coffee/15 bg-cream/60 rounded-sm font-serif text-lg text-coffee/80 transition-all hover:border-coffee/30 peer-checked:bg-terracotta peer-checked:text-cream peer-checked:border-terracotta peer-focus-visible:ring-2 peer-focus-visible:ring-terracotta/30 peer-focus-visible:ring-offset-2 peer-focus-visible:ring-offset-cream">
                      {n}
                    </div>
                  </label>
                ))
              }
            </div>
          </fieldset>

          <!-- Notes -->
          <div>
            <label
              for="r-notes"
              class="block font-mono text-[10px] uppercase tracking-[0.18em] text-coffee/60 mb-2"
            >
              Önskemål
              <span class="text-coffee/30 normal-case tracking-normal"
                >(valfritt)</span
              >
            </label>
            <textarea
              id="r-notes"
              name="notes"
              rows="3"
              placeholder="Allergier, högstol, fönsterbord…"
              class="w-full px-4 py-3 bg-cream/60 border border-coffee/15 rounded-sm text-coffee placeholder-coffee/30 focus:outline-none focus:border-terracotta focus:ring-2 focus:ring-terracotta/20 transition-all resize-none"
            ></textarea>
          </div>

          <!-- Submit -->
          <button
            type="submit"
            class="w-full px-7 py-4 bg-terracotta text-cream font-medium tracking-tight rounded-sm hover:bg-terracotta-deep transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-terracotta/30 focus-visible:ring-offset-2 focus-visible:ring-offset-cream"
          >
            Skicka bokning →
          </button>
        </form>

        <!-- Success state (hidden by default) -->
        <div
          id="reservation-success"
          class="hidden bg-sage/10 border border-sage/30 rounded-sm p-8 md:p-12 text-center"
        >
          <div class="font-serif italic font-light text-5xl text-sage mb-4">
            Tack!
          </div>
          <p
            class="text-base md:text-lg text-coffee/80 mb-3 leading-relaxed max-w-md mx-auto"
          >
            Vi har fått din bokningsförfrågan. Du får svar inom 4 timmar.
          </p>
          <p class="text-xs text-coffee/45 font-mono uppercase tracking-wider">
            Demo · inget har skickats på riktigt
          </p>
        </div>
      </div>
    </div>
  </Container>
</section>

<script>
  const form = document.getElementById(
    'reservation-form'
  ) as HTMLFormElement | null;
  const success = document.getElementById('reservation-success');

  if (form && success) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      form.classList.add('hidden');
      success.classList.remove('hidden');
      success.scrollIntoView({ behavior: 'smooth', block: 'center' });
    });
  }
</script>
