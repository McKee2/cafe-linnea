---
import Container from '../Container.astro';

const directionsUrl =
  'https://www.google.com/maps/dir/?api=1&destination=Bondegatan+27,+Stockholm';
---

<section
  id="hitta-hit"
  class="bg-sand/60 py-20 md:py-28 border-t border-coffee/8"
>
  <Container size="wide">
    <div
      class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-start"
    >
      <!-- Map (desktop left, mobile bottom) -->
      <div class="lg:col-span-7 order-2 lg:order-1">
        <div
          class="bg-cream/40 border border-coffee/10 rounded-sm overflow-hidden"
        >
          <svg
            viewBox="0 0 500 500"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full h-auto block"
            role="img"
            aria-label="Stiliserad karta över Bondegatan 27 på Söder, Stockholm"
          >
            <defs>
              <radialGradient id="pinGlow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#D97757" stop-opacity="0.28"
                ></stop>
                <stop offset="100%" stop-color="#D97757" stop-opacity="0"
                ></stop>
              </radialGradient>
            </defs>

            <!-- Base background -->
            <rect width="500" height="500" fill="#E8E2D0"></rect>

            <!-- City blocks (subtle sage rectangles) -->
            <g opacity="0.55" fill="#C8C9B0">
              <rect x="0" y="0" width="160" height="140" rx="2"></rect>
              <rect x="180" y="0" width="100" height="140" rx="2"></rect>
              <rect x="320" y="0" width="180" height="140" rx="2"></rect>
              <rect x="0" y="180" width="160" height="120" rx="2"></rect>
              <rect x="320" y="180" width="180" height="120" rx="2"></rect>
              <rect x="0" y="340" width="160" height="160" rx="2"></rect>
              <rect x="180" y="340" width="100" height="160" rx="2"></rect>
              <rect x="320" y="340" width="180" height="160" rx="2"></rect>
            </g>

            <!-- Nytorget park -->
            <rect
              x="180"
              y="180"
              width="100"
              height="120"
              fill="#7C8471"
              opacity="0.85"
              rx="3"></rect>
            <text
              x="230"
              y="246"
              font-family="ui-monospace, SF Mono, monospace"
              font-size="9"
              fill="#FBF6EE"
              letter-spacing="2"
              text-anchor="middle">NYTORGET</text
            >

            <!-- Horizontal streets -->
            <rect x="0" y="140" width="500" height="40" fill="#FBF6EE"></rect>
            <rect x="0" y="300" width="500" height="40" fill="#FBF6EE"></rect>

            <!-- Vertical streets -->
            <rect x="160" y="0" width="20" height="500" fill="#FBF6EE"></rect>
            <rect x="280" y="0" width="40" height="500" fill="#FBF6EE"></rect>

            <!-- Street labels -->
            <text
              x="16"
              y="166"
              font-family="ui-monospace, SF Mono, monospace"
              font-size="10"
              fill="#3D2C1E"
              opacity="0.55"
              letter-spacing="2">FOLKUNGAGATAN</text
            >
            <text
              x="16"
              y="326"
              font-family="ui-monospace, SF Mono, monospace"
              font-size="11"
              fill="#D97757"
              letter-spacing="2"
              font-weight="600">BONDEGATAN</text
            >

            <!-- North compass -->
            <g transform="translate(460, 36)" opacity="0.4">
              <line
                x1="0"
                y1="-10"
                x2="0"
                y2="10"
                stroke="#3D2C1E"
                stroke-width="1"></line>
              <polygon points="0,-10 -3,-4 3,-4" fill="#3D2C1E"></polygon>
              <text
                y="-16"
                font-family="ui-monospace, monospace"
                font-size="9"
                fill="#3D2C1E"
                text-anchor="middle">N</text
              >
            </g>

            <!-- The pin at Bondegatan × Östgötagatan -->
            <g transform="translate(300, 320)">
              <!-- Glow -->
              <circle r="42" fill="url(#pinGlow)"></circle>
              <!-- White ring -->
              <circle
                r="22"
                fill="#FBF6EE"
                stroke="#D97757"
                stroke-width="2.5"></circle>
              <!-- Inner dot -->
              <circle r="13" fill="#D97757"></circle>
            </g>

            <!-- Pin label below -->
            <g transform="translate(300, 380)">
              <rect
                x="-58"
                y="-16"
                width="116"
                height="32"
                fill="#FBF6EE"
                stroke="#D97757"
                stroke-width="1"
                rx="2"></rect>
              <text
                font-family="Georgia, serif"
                font-style="italic"
                font-size="18"
                fill="#3D2C1E"
                text-anchor="middle"
                y="6"
                >linnea<tspan fill="#D97757" font-style="normal">.</tspan></text
              >
            </g>
          </svg>
        </div>
        <p
          class="mt-3 font-mono text-[10px] uppercase tracking-[0.15em] text-coffee/45"
        >
          Stiliserad illustration · ej geografiskt skalriktig
        </p>
      </div>

      <!-- Info column (desktop right, mobile top) -->
      <div class="lg:col-span-5 order-1 lg:order-2">
        <p
          class="font-mono text-xs uppercase tracking-[0.2em] text-coffee/60 mb-6"
        >
          Hitta hit
        </p>

        <h2
          class="font-serif text-4xl md:text-5xl lg:text-6xl font-light text-coffee tracking-[-0.02em] leading-[1.05] mb-8"
        >
          Bondegatan 27, <span class="italic font-normal text-terracotta"
            >Söder</span
          >.
        </h2>

        <!-- Address + directions -->
        <div class="mb-10 pb-8 border-b border-coffee/15">
          <address
            class="font-serif text-xl md:text-2xl text-coffee leading-snug not-italic mb-5"
          >
            Café Linnea<br />
            Bondegatan 27<br />
            116 33 Stockholm
          </address>
          <a
            href={directionsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 text-terracotta hover:text-terracotta-deep transition-colors text-sm md:text-base font-medium"
          >
            Visa vägbeskrivning
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M7 17L17 7m0 0H8m9 0v9"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </a>
        </div>

        <!-- Transit -->
        <dl class="space-y-5 mb-8">
          <div class="grid grid-cols-[80px_1fr] gap-4 items-baseline">
            <dt class="font-mono text-xs uppercase tracking-[0.15em] text-sage">
              T-bana
            </dt>
            <dd class="text-sm md:text-base text-coffee/80 leading-relaxed">
              Medborgarplatsen, 3 min promenad
            </dd>
          </div>
          <div class="grid grid-cols-[80px_1fr] gap-4 items-baseline">
            <dt class="font-mono text-xs uppercase tracking-[0.15em] text-sage">
              Buss
            </dt>
            <dd class="text-sm md:text-base text-coffee/80 leading-relaxed">
              53, 76 till Folkungagatan
            </dd>
          </div>
          <div class="grid grid-cols-[80px_1fr] gap-4 items-baseline">
            <dt class="font-mono text-xs uppercase tracking-[0.15em] text-sage">
              Cykel
            </dt>
            <dd class="text-sm md:text-base text-coffee/80 leading-relaxed">
              Citybikes på Götgatan & Östgötagatan
            </dd>
          </div>
          <div class="grid grid-cols-[80px_1fr] gap-4 items-baseline">
            <dt class="font-mono text-xs uppercase tracking-[0.15em] text-sage">
              Bil
            </dt>
            <dd class="text-sm md:text-base text-coffee/80 leading-relaxed">
              Garage på Skånegatan, 5 min promenad
            </dd>
          </div>
        </dl>

        <!-- Accessibility note -->
        <p
          class="text-sm text-coffee/65 leading-relaxed border-l-2 border-sage/40 pl-4 italic font-serif"
        >
          Rullstolsvänligt — ingång och toalett i markplan.
        </p>
      </div>
    </div>
  </Container>
</section>
